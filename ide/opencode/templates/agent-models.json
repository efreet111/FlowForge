    }
  },
  "agents": {
    "flowforge": {
      "model": {
        "opencode-zen": "big-pickle",
        "opencode-go": "qwen3.7-plus"
      },
      "fallback": {
        "opencode-zen": "big-pickle",
        "opencode-go": "deepseek-v4-flash"
      },
      "mode": "primary",
      "purpose": "Orquestador y coordinador CKP"
    },
    "forge-discovery": {
      "model": {
        "opencode-zen": "deepseek-v4-flash-free",
        "opencode-go": "deepseek-v4-flash"
      },
      "fallback": {
        "opencode-zen": "deepseek-v4-flash-free",
        "opencode-go": "qwen3.7-plus"
      },
      "mode": "subagent",
      "purpose": "Mapeo de contexto y CKP-0"
    },
    "forge-arch": {
      "model": {
        "opencode-zen": "big-pickle",
        "opencode-go": "mimo-v2.5-pro"
      },
      "fallback": {
        "opencode-zen": "big-pickle",
        "opencode-go": "deepseek-v4-pro"
      },
      "mode": "subagent",
      "purpose": "Escritura de spec.md y análisis STRIDE"
    },
    "forge-plan": {
      "model": {
        "opencode-zen": "big-pickle",
        "opencode-go": "qwen3.7-plus"
      },
      "fallback": {
        "opencode-zen": "big-pickle",
        "opencode-go": "deepseek-v4-pro"
      },
      "mode": "subagent",
      "purpose": "Descomposición del plan y checklist"
    },
    "forge-dev": {
      "model": {
        "opencode-zen": "big-pickle",
        "opencode-go": "qwen3.7-plus"
      },
      "fallback": {
        "opencode-zen": "big-pickle",
        "opencode-go": "deepseek-v4-pro"
      },
      "mode": "subagent",
      "purpose": "Implementación y tests"
    },
    "forge-verify": {
      "model": {
        "opencode-zen": "minimax-m2.5-free",
        "opencode-go": "deepseek-v4-pro"
      },
      "fallback": {
        "opencode-zen": "minimax-m2.5-free",
        "opencode-go": "qwen3.7-plus"
      },
      "mode": "subagent",
      "purpose": "Auditoría y verify-report"
    },
    "forge-memory": {
      "model": {
        "opencode-zen": "deepseek-v4-flash-free",
        "opencode-go": "deepseek-v4-flash"
      },
      "fallback": {
        "opencode-zen": "deepseek-v4-flash-free",
        "opencode-go": "qwen3.7-plus"
      },
      "mode": "subagent",
      "purpose": "Cierre y memoria"
    },
    "forge-teacher": {
      "model": {
        "opencode-zen": "deepseek-v4-flash-free",
        "opencode-go": "deepseek-v4-flash"
      },
      "fallback": {
        "opencode-zen": "deepseek-v4-flash-free",
        "opencode-go": "qwen3.7-plus"
      },
      "mode": "subagent",
      "purpose": "Explicaciones y teaching"
    },
    "default": {
      "model": {
        "opencode-zen": "big-pickle",
        "opencode-go": "qwen3.7-plus"
      },
      "fallback": {
        "opencode-zen": "big-pickle",
        "opencode-go": "deepseek-v4-flash"
      },
      "mode": "primary",
      "purpose": "Valor por defecto para agents desconocidos"
    }
  }
}
