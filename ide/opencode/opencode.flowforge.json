      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:__FLOWFORGE_REPO__/skills/forge-memory/SKILL.md}\n\nTambién cargá on-demand:\n- {file:__FLOWFORGE_REPO__/skills/forge-memory/metrics/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-memory/changelog/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-memory/knowledge/SKILL.md}",
