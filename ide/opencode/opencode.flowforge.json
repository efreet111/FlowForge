{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "FlowForge agents for OpenCode. Merge into your main opencode.json or use as standalone with your existing MCP/permission config.",

  "agent": {
    "flowforge": {
      "description": "FlowForge Orchestrator — 6 fases, 7 agentes",
      "mode": "primary",
      "model": "opencode-go/qwen3.5-plus",
      "prompt": "{file:./flowforge/AGENTS.md}\n\n{file:./flowforge/shared/workflow-orchestrator-parity.md}\n\n## FlowForge Orchestrator (OpenCode)\n\nEres el ORQUESTADOR. Delegá cada fase al subagente correspondiente (task tool). Nunca implementes spec, plan, código producto, verify-report ni parches de dashboard/métricas inline.\n\nCheckpoints: CKP-0 🔴 vago=STOP | CKP-1/2 🟡 spec/plan humano | CKP-3 🔴 3 reworks=escala | CKP-4 🟢 deploy humano.\n\nBug reportado → rework_ticket.md + forge-dev. Cierre → forge-memory solo si PM-* [x] en spec.md.",
      "tools": {
        "edit": true,
        "write": true,
        "read": true,
        "bash": true,
        "task": true
      }
    },

    "forge-discovery": {
      "description": "FlowForge Discovery — Mapeo de contexto [DeepSeek V4 Flash]",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:__FLOWFORGE_REPO__/skills/forge-discovery/SKILL.md}\n\nTambién cargá on-demand:\n- {file:__FLOWFORGE_REPO__/skills/forge-discovery/security/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-discovery/compliance/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-discovery/cost/SKILL.md}",
      "tools": {
        "bash": true,
        "read": true
      }
    },

    "forge-arch": {
      "description": "FlowForge Arch — Especificación y STRIDE [DeepSeek V4 Pro]",
      "hidden": true,
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:__FLOWFORGE_REPO__/skills/forge-arch/SKILL.md}\n\nTambién cargá on-demand:\n- {file:__FLOWFORGE_REPO__/skills/forge-arch/security/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-arch/performance/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-arch/a11y/SKILL.md}\n- {file:__FLOWFORGE_REPO__/skills/forge-arch/domain/SKILL.md}",
